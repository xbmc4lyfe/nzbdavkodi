# Copy to .env and fill in. .env is gitignored.
PUID=1000
PGID=1000
TZ=Australia/Sydney

# Host ports (change if they clash with other services on this host)
NZBHYDRA2_PORT=5076
NZBDAV_PORT=3000

# NNTP provider — NOT auto-applied. You enter these in the nzbdav web UI
# on first-run (Settings > Usenet). Kept here for copy/paste convenience.
NNTP_HOST=news.example.com
NNTP_PORT=563
NNTP_USER=changeme
NNTP_PASS=changeme
NNTP_CONNECTIONS=4
NNTP_SSL=true
