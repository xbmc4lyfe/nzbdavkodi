# Copy to .env and fill in. .env is gitignored.

# Path to the local nzbdav-rs checkout (resolved relative to dev/).
NZBDAV_RS_PATH=../../../../apps/nzbdav-rs

# Host port nzbdav-rs is published on (container always listens on 8080).
# Default 8180 avoids clashes with other dev services commonly holding 8080.
NZBDAV_PORT=8180
NZBDAV_LOG=info

# Env-driven nzbdav-rs config — applied at container start, skips the
# web-UI first-run for these three.
NZBDAV_API_KEY=smokekey-dev-only
WEBDAV_USER=admin
WEBDAV_PASS=devpass

# NNTP provider — NOT auto-applied. You enter these in the nzbdav
# web UI (Servers tab) once on first run. Kept here for copy/paste.
NNTP_HOST=news.example.com
NNTP_PORT=563
NNTP_USER=changeme
NNTP_PASS=changeme
NNTP_CONNECTIONS=4
NNTP_SSL=true
