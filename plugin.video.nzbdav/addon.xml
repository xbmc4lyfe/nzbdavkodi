<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.nzbdav"
       name="NZB-DAV"
       version="0.1.0"
       provider-name="nzbdav">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="addon.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">NZB-DAV Usenet streaming for Kodi</summary>
        <summary lang="en">NZB-DAV Usenet streaming for Kodi</summary>
        <description lang="en_GB">Search NZBHydra2 for NZBs and stream via nzbdav WebDAV. Works as a TMDBHelper player.</description>
        <description lang="en">Search NZBHydra2 for NZBs and stream via nzbdav WebDAV. Works as a TMDBHelper player.</description>
        <platform>all</platform>
        <license>GPL-3.0-or-later</license>
        <news>v0.1.0 - Initial release</news>
        <assets>
            <icon>resources/icon.png</icon>
            <fanart>resources/fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
