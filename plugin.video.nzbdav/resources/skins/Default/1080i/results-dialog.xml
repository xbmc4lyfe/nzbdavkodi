<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog" id="1100">
  <defaultcontrol always="true">50</defaultcontrol>
  <coordinates>
    <system>1</system>
  </coordinates>
  <controls>

    <!-- Full-screen dark background -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>1080</height>
      <colordiffuse>FF0A0A0A</colordiffuse>
      <texture>white.png</texture>
    </control>

    <!-- Header background -->
    <control type="image">
      <left>0</left><top>0</top><width>1920</width><height>60</height>
      <colordiffuse>FF151520</colordiffuse>
      <texture>white.png</texture>
    </control>

    <!-- Header: Movie title -->
    <control type="label" id="1">
      <left>20</left><top>8</top><width>1400</width><height>28</height>
      <label>$INFO[Window.Property(title)]</label>
      <font>font13</font>
      <textcolor>FFFFFFFF</textcolor>
      <aligny>center</aligny>
    </control>

    <!-- Header: Subtitle -->
    <control type="label" id="2">
      <left>20</left><top>34</top><width>600</width><height>20</height>
      <label>NZB-DAV · NZBHydra2</label>
      <font>font10</font>
      <textcolor>FF666666</textcolor>
