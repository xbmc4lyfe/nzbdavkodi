<?xml version="1.0" encoding="utf-8"?>
<settings version="1">
    <section id="plugin.video.nzbdav">
        <category id="connection" label="Connection">
            <group id="hydra" label="NZBHydra2">
                <setting id="hydra_url" type="string" label="NZBHydra2 URL">
                    <default>http://localhost:5076</default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="hydra_api_key" type="string" label="API Key">
                    <default></default>
                    <control type="edit" format="string" hidden="true" />
                </setting>
            </group>
            <group id="nzbdav_conn" label="nzbdav">
                <setting id="nzbdav_url" type="string" label="nzbdav URL">
                    <default>http://localhost:3000</default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="nzbdav_api_key" type="string" label="API Key">
                    <default></default>
                    <control type="edit" format="string" hidden="true" />
                </setting>
            </group>
            <group id="webdav" label="WebDAV">
                <setting id="webdav_url" type="string" label="WebDAV URL (leave empty to use nzbdav URL)">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="webdav_username" type="string" label="Username">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="webdav_password" type="string" label="Password">
                    <default></default>
                    <control type="edit" format="string" hidden="true" />
                </setting>
            </group>
        </category>
        <category id="player_install" label="Player Installation">
            <group id="targets" label="Install player file to">
                <setting id="install_tmdbhelper" type="boolean" label="TMDBHelper">
                    <default>false</default>
                    <control type="toggle" />
                </setting>
                <setting id="install_fen" type="boolean" label="Fen">
                    <default>false</default>
                    <control type="toggle" />
                </setting>
                <setting id="install_seren" type="boolean" label="Seren">
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="action" label="Actions">
                <setting id="install_player_action" type="action" label="Install Player File">
                    <default></default>
                    <control type="button" />
                    <data action="RunPlugin(plugin://plugin.video.nzbdav/install_player)" />
                </setting>
            </group>
        </category>
        <category id="filters" label="Quality Filters">
            <group id="resolution" label="Resolution">
                <setting id="filter_2160p" type="boolean" label="2160p / 4K">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_1080p" type="boolean" label="1080p">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_720p" type="boolean" label="720p">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_480p" type="boolean" label="480p">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="hdr" label="HDR">
                <setting id="filter_hdr10" type="boolean" label="HDR10">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_hdr10plus" type="boolean" label="HDR10+">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_dolby_vision" type="boolean" label="Dolby Vision">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_hlg" type="boolean" label="HLG">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_sdr" type="boolean" label="SDR">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="audio" label="Audio">
                <setting id="filter_atmos" type="boolean" label="Atmos">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_truehd" type="boolean" label="TrueHD">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_dtshd_ma" type="boolean" label="DTS-HD MA">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_dtsx" type="boolean" label="DTS:X">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_ddplus" type="boolean" label="DD+ (EAC3)">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_dd" type="boolean" label="DD (AC3)">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_aac" type="boolean" label="AAC">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="codec" label="Video Codec">
                <setting id="filter_hevc" type="boolean" label="x265 / HEVC">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_avc" type="boolean" label="x264 / AVC">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_av1" type="boolean" label="AV1">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_vp9" type="boolean" label="VP9">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_mpeg2" type="boolean" label="MPEG-2">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
            <group id="language" label="Language">
                <setting id="filter_english" type="boolean" label="English">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_spanish" type="boolean" label="Spanish">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_french" type="boolean" label="French">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_german" type="boolean" label="German">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_italian" type="boolean" label="Italian">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_portuguese" type="boolean" label="Portuguese">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_dutch" type="boolean" label="Dutch">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_russian" type="boolean" label="Russian">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_japanese" type="boolean" label="Japanese">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_korean" type="boolean" label="Korean">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_chinese" type="boolean" label="Chinese">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_arabic" type="boolean" label="Arabic">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="filter_hindi" type="boolean" label="Hindi">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>
        <category id="keyword_filters" label="Keyword Filters">
            <group id="release_groups" label="Release Groups">
                <setting id="filter_release_group" type="string" label="Preferred groups (comma-separated)">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="filter_exclude_release_group" type="string" label="Excluded groups (comma-separated)">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
            </group>
            <group id="size" label="File Size">
                <setting id="filter_min_size" type="integer" label="Min size (MB, 0=no limit)">
                    <default>0</default>
                    <control type="edit" format="integer" />
                </setting>
                <setting id="filter_max_size" type="integer" label="Max size (MB, 0=no limit)">
                    <default>0</default>
                    <control type="edit" format="integer" />
                </setting>
            </group>
            <group id="keywords" label="Keywords">
                <setting id="filter_exclude_keywords" type="string" label="Exclude keywords (comma-separated)">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
                <setting id="filter_require_keywords" type="string" label="Required keywords (comma-separated)">
                    <default></default>
                    <control type="edit" format="string" />
                </setting>
            </group>
        </category>
        <category id="sorting" label="Sorting &amp; Display">
            <group id="sort" label="Sort Order">
                <setting id="sort_order" type="integer" label="Sort by">
                    <default>0</default>
                    <constraints>
                        <options>
                            <option label="Relevance">0</option>
                            <option label="Size (largest first)">1</option>
                            <option label="Size (smallest first)">2</option>
                            <option label="Age (newest first)">3</option>
                            <option label="Age (oldest first)">4</option>
                        </options>
                    </constraints>
                    <control type="spinner" format="string" />
                </setting>
                <setting id="max_results" type="integer" label="Max results">
                    <default>25</default>
                    <control type="edit" format="integer" />
                </setting>
            </group>
            <group id="auto" label="Auto-Select">
                <setting id="auto_select_best" type="boolean" label="Auto-select best match (skip result list)">
                    <default>false</default>
                    <control type="toggle" />
                </setting>
            </group>
        </category>
        <category id="advanced" label="Advanced">
            <group id="polling" label="Polling">
                <setting id="poll_interval" type="integer" label="Poll interval (seconds)">
                    <default>5</default>
                    <control type="edit" format="integer" />
                </setting>
                <setting id="download_timeout" type="integer" label="Download timeout (seconds)">
                    <default>3600</default>
                    <control type="edit" format="integer" />
                </setting>
            </group>
            <group id="cache" label="Search Cache">
                <setting id="cache_ttl" type="integer" label="Cache duration (seconds, 0=disabled)">
                    <default>300</default>
                    <control type="edit" format="integer" />
                </setting>
            </group>
            <group id="resilience" label="Stream Resilience">
                <setting id="stream_auto_retry" type="boolean" label="Auto-retry on stream failure">
                    <default>true</default>
                    <control type="toggle" />
                </setting>
                <setting id="stream_max_retries" type="integer" label="Max retry attempts">
                    <default>3</default>
                    <control type="edit" format="integer" />
                </setting>
                <setting id="stream_retry_delay" type="integer" label="Retry delay (seconds)">
                    <default>5</default>
                    <control type="edit" format="integer" />
                </setting>
            </group>
        </category>
    </section>
</settings>
